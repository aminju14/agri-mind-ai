# AgriMind AI — environment template (copy to .env and fill in)
# See docs/ARCHITECTURE.md §12 for the full config contract.

# --- Database (PostgreSQL + pgvector) ---
# Use a pgvector-enabled Postgres (e.g. image pgvector/pgvector:pg16).
#
# DATABASE_URL: the APP connection. For RLS tenant-isolation to actually take effect,
# this MUST be a NON-superuser role (e.g. agrimind_app), because superusers bypass RLS.
# Create the role once via: ops/sql/create-app-role.sql  (docs/DATABASE.md §13.2).
#   DATABASE_URL="postgresql://agrimind_app:<app_password>@localhost:5432/agrimind?schema=public"
# For local single-user dev you MAY use the owner role, but RLS will then be bypassed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agrimind?schema=public"
# DIRECT_URL: the OWNER/admin connection used by `prisma migrate` (DDL). Keep as the
# privileged role (docs/DATABASE.md §16.1). Migrations must NOT run as agrimind_app.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/agrimind?schema=public"

# --- Embeddings (RAG) ---
# Must equal the vector(N) column dim and the model output dim (docs/DATABASE.md §12.3).
EMBED_DIM=1536
OPENAI_EMBED_MODEL="text-embedding-3-large"
# OPENAI_API_KEY=        # required once RAG (Phase 4) is wired

# --- Generation (Anthropic) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL="claude-opus-4-8"

# --- Web Search (Tavily) ---
# Get your key at https://tavily.com → Dashboard → API Keys
# Format: tvly-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# When absent, web search is simply disabled — no errors, RAG-only fallback.
# TAVILY_API_KEY=

# --- Auth.js v5 ---
# AUTH_SECRET=

# --- Limits ---
APP_RATE_LIMIT_PER_MIN=20
